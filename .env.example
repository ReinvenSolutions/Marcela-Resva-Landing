# MailerLite Configuration
MAILERLITE_API_KEY=your_mailerlite_api_key_here
MAILERLITE_GROUP_ID=your_mailerlite_group_id_here

# Grupo "Lista de espera membresía" en MailerLite (formulario /membresia)
# Dashboard: https://dashboard.mailerlite.com/subscribers?group=186595306235758499
MAILERLITE_GROUP_ID_LISTA_ESPERA_MEMBRESIA=186595306235758499

# Raíz del repo (junto a vite.config.ts). Vite usa este .env aunque el código viva en client/.
# Landing /libro (Vite: solo variables con prefijo VITE_ en el bundle; puedes duplicar pk_ en ambas o solo STRIPE_ + VITE_)
# Si defines VITE_LIBRO_CHECKOUT_URL, los botones de compra irán a esa URL en lugar de Stripe.
# VITE_LIBRO_CHECKOUT_URL=https://tu-tienda.com/producto
# VITE_LIBRO_PORTADA_URL= (opcional; por defecto: asset libro-llego-mi-momento-portada.png en el repo)

# ==============================================================================
# STRIPE (ebook /libro) — guía completa: ver STRIPE.md en la raíz del repo
# ==============================================================================
#
# DESARROLLO LOCAL → usa claves TEST (pk_test_ / sk_test_)
#   - Ve a: https://dashboard.stripe.com/test/apikeys
#   - No cobras dinero real; usa tarjeta de prueba 4242 4242 4242 4242
#   - Para probar webhooks localmente: stripe listen --forward-to localhost:5176/.netlify/functions/stripe-webhook-libro
#
# PRODUCCIÓN (Netlify) → usa claves LIVE (pk_live_ / sk_live_)
#   - Ve a: https://dashboard.stripe.com/apikeys
#   - Configura en: Netlify → Site settings → Environment variables
#   - NO incluyas claves live en este archivo .env (que se sube a Git solo con .env.example)
#
# Diagnóstico: si algo falla, visita /.netlify/functions/stripe-check en tu servidor local
# para ver si la clave es válida.
# ==============================================================================

# URL principal del sitio (Netlify la inyecta como URL en deploy; opcional en local)
# URL=https://marcelaresva.com

# Clave pública (pk_) — va al bundle del navegador, es seguro que sea pública
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Misma clave pública con prefijo VITE_ para que Vite la exponga en import.meta.env
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Clave secreta (sk_) — SOLO en el servidor (función Netlify); NUNCA en el cliente
STRIPE_SECRET_KEY=sk_test_xxx

# Signing secret del webhook: /.netlify/functions/stripe-webhook-libro
# En local: lo provee el comando `stripe listen` (comienza con whsec_)
# En Netlify: lo obtienes de Stripe Dashboard → Developers → Webhooks → tu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ==============================================================================
# RESEND — envío transaccional del libro PDF tras el pago
# ==============================================================================
# 1. Crea cuenta en https://resend.com (gratis hasta 3.000 emails/mes, 100/día)
# 2. Ve a API Keys → Create API Key → copia aquí
# 3. Ve a Domains → Add Domain → verifica tu dominio (ej. marcelaresva.com)
# 4. Agrega RESEND_API_KEY y RESEND_FROM_EMAIL en Netlify → Site settings → Environment variables
# ==============================================================================
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX
# Dirección "De:" que verán los compradores (debe ser de tu dominio verificado en Resend)
RESEND_FROM_EMAIL=Marcela Resva <hola@marcelaresva.com>
